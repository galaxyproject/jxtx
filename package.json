{
  "name": "jxtx",
  "version": "2.0.0",
  "private": true,
  "description": "jxtx",
  "keywords": ["astro"],
  "engines": { "node": ">=22" },
  "scripts": {
    "develop": "astro dev --port 5598",
    "start": "astro dev --port 5598",
    "build": "astro build",
    "serve": "astro preview --port 5598",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\"",
    "test": "playwright test smoke-test.spec.js",
    "test:all": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "parity:baseline": "node parity/capture.mjs --out parity/baseline",
    "parity:candidate": "node parity/capture.mjs --out parity/candidate",
    "parity:compare": "node parity/compare.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/react": "^6.0.1",
    "astro": "^7.0.7",
    "classnames": "^2.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-external-links": "^3.0.0",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "http-server": "^14.1.1",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "prettier": "2.8.1"
  }
}
