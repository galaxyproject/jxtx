---
import { getCollection, getEntry } from "astro:content";
import { getImage } from "astro:assets";
import BaseLayout from "../layouts/base-layout.astro";
import Section from "../components/section/section";
import ArticleH1 from "../components/article-typographies/article-h1";
import AwardeeGallery from "../components/awardee-gallery/awardee-gallery";
import { resolveImage } from "../lib/images.js";
import { routeForEntry, isAwardeeProfile } from "../lib/routes.js";

const listing = await getEntry("content", "/awardees-content/");
const entries = await getCollection("content");
const profiles = entries.filter(isAwardeeProfile);
const awardees = (
  await Promise.all(
    profiles.map(async (entry) => ({
      name: entry.data.name,
      institution: entry.data.institution,
      photo: entry.data.photo
        ? await resolveImage(entry.data.photo, { width: 400, height: 400, avif: true, placeholder: "blurred" })
        : null,
      conference: entry.data.conference,
      year: entry.data.year,
      program: entry.data.program,
      slug: routeForEntry(entry),
    }))
  )
).sort((a, b) => (a.year !== b.year ? b.year - a.year : a.name.localeCompare(b.name)));

const seoImage = listing.data.image ? (await getImage({ src: listing.data.image })).src : undefined;
---
<BaseLayout
  headerMinor
  pathname="/awardees"
  title={listing.data.title}
  description={listing.data.description}
  image={seoImage}
>
  <Section>
    <div style="max-width:1200px;margin:0 auto;padding:2rem 1rem">
      <ArticleH1>Awardees</ArticleH1>
      <p style="font-size:0.95rem;line-height:1.5;margin-bottom:1rem;color:#333">
        The JXTX Foundation provides scholarships to graduate students and postdoctoral
        researchers to attend conferences in computational biology and data science. These
        scholarships enable the next generation of researchers to present their work, build
        community connections, and advance open science.
      </p>
      <p style="font-size:0.95rem;line-height:1.5;margin-bottom:2rem;color:#333">
        Our awardees carry forward James Taylor's legacy through their commitment to open,
        reproducible research and their contributions to the computational biology community.
      </p>
    </div>
    <AwardeeGallery awardees={awardees} />
  </Section>
</BaseLayout>
