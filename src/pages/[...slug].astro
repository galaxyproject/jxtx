---
import { getCollection, render } from "astro:content";
import { getImage } from "astro:assets";
import BaseLayout from "../layouts/base-layout.astro";
import ArticleMain from "../components/article-main/article-main";
import Section from "../components/section/section";
import { SectionType } from "../components/section/section-type.model";
import { shortcodes, articleShortcodes } from "../lib/shortcodes.js";
import { resolveImage } from "../lib/images.js";
import { routeForEntry, paramForEntry, isAwardeeProfile } from "../lib/routes.js";

export async function getStaticPaths() {
  const entries = await getCollection("content");
  return entries.map((entry) => ({
    params: { slug: paramForEntry(entry) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const route = routeForEntry(entry);

const images = entry.data.images
  ? await Promise.all(entry.data.images.map((img) => resolveImage(img)))
  : undefined;
const links = entry.data.links;
const seoImage = entry.data.image
  ? (await getImage({ src: entry.data.image })).src
  : undefined;
const components = entry.data.fullWidth
  ? shortcodes
  : { ...shortcodes, ...articleShortcodes };
---
<BaseLayout
  headerMinor
  pathname={route}
  title={entry.data.title}
  description={entry.data.description}
  image={seoImage}
>
  <ArticleMain>
    {entry.data.fullWidth ? (
      <Content components={components} images={images} links={links} />
    ) : (
      <Section type={SectionType.ARTICLE}>
        <Content components={components} images={images} links={links} />
      </Section>
    )}
  </ArticleMain>
</BaseLayout>
